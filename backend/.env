# Ojasya Healthcare Backend Environment Variables
# Copy this to .env and fill in your values

PORT=5000
NODE_ENV=development

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=201106
DB_NAME=ojasya_healthcare

# JWT Secret (use a long random string in production)
JWT_SECRET=ojasya_super_secret_jwt_key_change_in_production_2024
JWT_EXPIRES_IN=24h

# Admin default credentials (change after first login)
ADMIN_EMAIL=admin@ojasya.com
ADMIN_PASSWORD=Admin@123

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
